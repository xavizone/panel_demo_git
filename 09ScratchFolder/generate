import json
import random
import uuid

def generate_record():
    # Hardcoded lists to mimic "Faker"
    domains = ["gmail.com", "yahoo.com", "hotmail.com", "outlook.com"]
    avatars = ["Violet", "DarkGreen", "Bisque", "SaddleBrown", "Aqua"]
    
    # Generate random email
    user_id = str(uuid.uuid4())[:8]
    email = "user_" + user_id + "@" + random.choice(domains)
    
    # Generate realistic stats
    avg_session = round(random.uniform(29.0, 36.0), 4)
    time_on_app = round(random.uniform(9.0, 15.0), 4)
    membership = round(random.uniform(0.5, 6.0), 4)
    
    # Simple linear logic for spend (Membership * 60 + noise)
    spent = (membership * 65) + (time_on_app * 30) + random.uniform(50, 150)

    return {
        "Email": email,
        "Avatar": random.choice(avatars),
        "Avg. Session Length": str(avg_session),
        "Time on App": str(time_on_app),
        "Length of Membership": str(membership),
        "Yearly Amount Spent": str(round(spent, 2))
    }

# NiFi session logic
flowFile = session.create()
