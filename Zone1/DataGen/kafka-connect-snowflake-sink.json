{
    "name": "snowflake-iceberg-sink-orders",
    "config": {
        "connector.class": "com.snowflake.kafka.connector.SnowflakeSinkConnector",
        "tasks.max": "2",

        "topics": "tasty_bytes.orders,tasty_bytes.customers,tasty_bytes.clickstream,tasty_bytes.menu",
        "topics.regex": "",

        "snowflake.url.name": "st83997.snowflakecomputing.com",
        "snowflake.user.name": "XAVIZONE",
        "snowflake.private.key": "${file:/opt/kafka/secrets/snowflake.properties:snowflake.private.key}",
        "snowflake.role.name": "ACCOUNTADMIN",
        "snowflake.database.name": "TASTY_BYTES_DEMO",
        "snowflake.schema.name": "DEV",

        "snowflake.ingestion.method": "SNOWPIPE_STREAMING",
        "snowflake.enable.schematization": "true",

        "topic2table.map": "tasty_bytes.orders:RAW_ORDERS,tasty_bytes.customers:RAW_CUSTOMERS,tasty_bytes.clickstream:RAW_CLICKSTREAM,tasty_bytes.menu:RAW_MENU",

        "key.converter": "org.apache.kafka.connect.storage.StringConverter",
        "value.converter": "org.apache.kafka.connect.json.JsonConverter",
        "value.converter.schemas.enable": "false",

        "buffer.count.records": "1000",
        "buffer.flush.time": "10",
        "buffer.size.bytes": "5242880",

        "errors.tolerance": "all",
        "errors.log.enable": "true",
        "errors.log.include.messages": "true",
        "errors.deadletterqueue.topic.name": "tasty_bytes_dlq",
        "errors.deadletterqueue.topic.replication.factor": "1"
    }
}
